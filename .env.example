# App
# In Vercel production, set both URLs to https://your-domain.com.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
AUTH_SECRET=change-me-with-openssl-rand-base64-32
CONFIG_ENCRYPTION_KEY=change-me-32-byte-key-base64-or-long-secret

# Database - PostgreSQL
# Use a managed Postgres URL in Vercel, Neon, Supabase, Railway, AWS RDS, etc.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payflow?schema=public

# WhatsApp
# Use "mock" for demo mode, "evolution" for local QR-code mode, or "meta" for WhatsApp Cloud API.
# On Vercel, do not point EVOLUTION_API_BASE_URL to localhost. Evolution needs a public HTTPS host.
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=payflow-evolution-local-key
EVOLUTION_INSTANCE_NAME=payflow-local
WHATSAPP_WEBHOOK_URL=http://host.docker.internal:3000/api/webhooks/whatsapp
# Optional fallback for public tracking links /go/[oferta] when Evolution cannot return ownerJid.
WHATSAPP_REDIRECT_NUMBER=
CONFIG_SESSION_PHONE_CLIENT=PayFlow
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=60
QRCODE_COLOR=#001A42
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=payflow-local-verify
WHATSAPP_WEBHOOK_SECRET=

# Umbrella / UmbrellaPag
# Production webhook: https://pay-flow.shop/api/webhooks/umbrella
UMBRELLA_API_BASE_URL=
UMBRELLA_API_KEY=
UMBRELLA_USER_AGENT=UMBRELLAB2B/1.0
UMBRELLA_WEBHOOK_SECRET=

# Payment gateways
# Never expose these values in frontend code. Configure real values only in the server/Vercel env.
TRIBOPAY_API_BASE_URL=https://api.tribopay.com.br/api/public/v1
TRIBOPAY_API_TOKEN=
TRIBOPAY_WEBHOOK_SECRET=
MANGOFY_API_KEY=
SIGILOPAY_PUBLIC_KEY=
SIGILOPAY_PRIVATE_KEY=
LYTRON_API_BASE_URL=https://api.lytronpay.com/api/v1
LYTRON_API_ACCESS_KEY=
LYTRON_API_SECRET_HASH=
LYTRON_SELLER_ID=
ALLOWPAYMENTS_SECRET_KEY=
ALLOWPAYMENTS_COMPANY_ID=

# Utmify
# Optional. Defaults to https://api.utmify.com.br/api-credentials/orders.
UTMIFY_API_BASE_URL=
UTMIFY_API_KEY=
UTMIFY_WEBHOOK_SECRET=

# Meta Ads
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_MARKETING_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_BUSINESS_ID=
META_PAGE_ID=
META_PIXEL_ID=
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v25.0
META_CAPI_TEST_EVENT_CODE=
