# App
# In Vercel production, set both URLs to https://your-domain.com.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
AUTH_SECRET=change-me-with-openssl-rand-base64-32
CONFIG_ENCRYPTION_KEY=change-me-32-byte-key-base64-or-long-secret

# Database - PostgreSQL
# Use a managed Postgres URL in Vercel, Neon, Supabase, Railway, AWS RDS, etc.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payflow?schema=public

# WhatsApp
# Use "mock" for demo mode, "evolution" for local QR-code mode, or "meta" for WhatsApp Cloud API.
# On Vercel, do not point EVOLUTION_API_BASE_URL to localhost. Evolution needs a public HTTPS host.
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=payflow-evolution-local-key
EVOLUTION_INSTANCE_NAME=payflow-local
WHATSAPP_WEBHOOK_URL=http://host.docker.internal:3000/api/webhooks/whatsapp
CONFIG_SESSION_PHONE_CLIENT=PayFlow
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=60
QRCODE_COLOR=#001A42
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=payflow-local-verify
WHATSAPP_WEBHOOK_SECRET=

# Umbrella / UmbrellaPag
# Production webhook: https://pay-flow.shop/api/webhooks/umbrella
UMBRELLA_API_BASE_URL=
UMBRELLA_API_KEY=
UMBRELLA_USER_AGENT=UMBRELLAB2B/1.0
UMBRELLA_WEBHOOK_SECRET=

# Utmify
UTMIFY_API_BASE_URL=
UTMIFY_API_KEY=
UTMIFY_WEBHOOK_SECRET=

# Meta Ads
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
